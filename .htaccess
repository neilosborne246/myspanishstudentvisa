# ============================================================
# myspanishstudentvisa.com — performance & canonical config
# ============================================================

# ---- Force HTTPS + non-www (matches site canonical) ----
<IfModule mod_rewrite.c>
  RewriteEngine On
  # http -> https
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # www -> non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # ---- 301 redirects: retired/renamed URLs (fixes GSC 404s) ----
  RewriteRule ^compare/golden-visa/?$ /compare/ [L,R=301]
  RewriteRule ^by-nationality/spain-student-visa-china/?$ /by-nationality/ [L,R=301]
  RewriteRule ^renewal/documents/?$ /blog/spain-student-visa-renewal-documents-checklist/ [L,R=301]
  RewriteRule ^renewal/financial/?$ /blog/spain-student-visa-renewal-financial-requirements/ [L,R=301]
  RewriteRule ^renewal/refused/?$ /renewal/renewal-refused/ [L,R=301]
  RewriteRule ^life/bank-account/?$ /after-arrival/bank-account/ [L,R=301]
  RewriteRule ^life/health-card/?$ /after-arrival/health-card/ [L,R=301]
  RewriteRule ^blog/staying-spain-after-graduation/?$ /blog/staying-in-spain-after-graduation-options/ [L,R=301]
  RewriteRule ^blog/spain-job-seeker-visa-graduates/?$ /blog/job-seeker-visa-spain-graduates/ [L,R=301]
</IfModule>

# ---- Gzip / Deflate compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# ---- Browser caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType text/javascript         "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# ---- Cache-Control headers (long cache for static assets, none for HTML) ----
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
